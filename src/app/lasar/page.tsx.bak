const AfACalculator = () => {
    const [step, setStep] = useState(1);
    const [savings, setSavings] = useState(0);

    const nextStep = () => {
        if (step === 4) {
             setSavings(Math.floor(Math.random() * 50000) + 10000);
        }
        setStep(prev => Math.min(prev + 1, 5));
    };
    const prevStep = () => setStep(prev => Math.max(prev - 1, 1));

    return (
        <section id="afa-rechner" className="py-32 bg-[#FCF0E8] px-6 relative">
            <div className="max-w-5xl mx-auto">
                <div className="text-center mb-20">
                    <span className="text-[#1A758D] font-black uppercase tracking-[0.34em] text-[12px] mb-4 block">AfA-Rechner Pro</span>
                    <h2 className="text-5xl lg:text-7xl font-black text-[#1a1a1a] mb-8 tracking-tighter">Wie viel können Sie sparen?</h2>
                    <p className="text-gray-600 text-xl max-w-2xl mx-auto font-medium">Berechnen Sie jetzt kostenlos Ihr individuelles Sparpotenzial mit einem offiziellen LASARZ Gutachten.</p>
                </div>

                <div className="bg-white rounded-[4rem] shadow-[0_60px_120px_-30px_rgba(0,0,0,0.1)] overflow-hidden border border-white/50">
                    {/* Progress Bar */}
                    <div className="flex bg-gray-50/50">
                        {[1, 2, 3, 4, 5].map(s => (
                            <div key={s} className="flex-1 h-3 relative">
                                <div className={`absolute inset-0 transition-all duration-700 ${step >= s ? 'bg-[#1A758D]' : 'bg-gray-200'}`}></div>
                            </div>
                        ))}
                    </div>
                    
                    <div className="p-8 lg:p-20">
                        {step === 1 && (
                            <div className="space-y-10 animate-fade-in">
                                <h3 className="text-3xl lg:text-4xl font-black mb-10 text-center lg:text-left">1. Angaben zum Kauf</h3>
                                <div className="grid md:grid-cols-2 gap-10">
                                    <div>
                                        <label className="block text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Gesamtkaufpreis (€)</label>
                                        <input type="number" className="w-full p-6 bg-gray-50 border-2 border-transparent focus:border-[#1A758D]/20 focus:bg-white rounded-2xl outline-none font-bold text-xl transition-all" placeholder="500.000" />
                                    </div>
                                    <div>
                                        <label className="block text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Kaufdatum / Übergang</label>
                                        <input type="date" className="w-full p-6 bg-gray-50 border-2 border-transparent focus:border-[#1A758D]/20 focus:bg-white rounded-2xl outline-none font-bold text-xl transition-all" />
                                    </div>
                                </div>
                            </div>
                        )}
                        {step === 2 && (
                            <div className="space-y-10 animate-fade-in">
                                <h3 className="text-3xl lg:text-4xl font-black mb-10 text-center lg:text-left">2. Angaben zum Objekt</h3>
                                <div className="grid md:grid-cols-2 gap-10">
                                    <div>
                                        <label className="block text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Baujahr des Gebäudes</label>
                                        <input type="number" className="w-full p-6 bg-gray-50 border-2 border-transparent focus:border-[#1A758D]/20 focus:bg-white rounded-2xl outline-none font-bold text-xl transition-all" placeholder="1980" />
                                    </div>
                                    <div>
                                        <label className="block text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Wohnfläche (qm)</label>
                                        <input type="number" className="w-full p-6 bg-gray-50 border-2 border-transparent focus:border-[#1A758D]/20 focus:bg-white rounded-2xl outline-none font-bold text-xl transition-all" placeholder="120" />
                                    </div>
                                </div>
                            </div>
                        )}
                        {step === 3 && (
                            <div className="space-y-10 animate-fade-in">
                                <h3 className="text-3xl lg:text-4xl font-black mb-10 text-center lg:text-left">3. Aktuelle Nutzungsdauer</h3>
                                <p className="text-gray-500 text-lg mb-8">Welche Nutzungsdauer wird aktuell für die Abschreibung herangezogen?</p>
                                <div className="grid grid-cols-1 sm:grid-cols-3 gap-6">
                                    {['50 Jahre', '40 Jahre', '33 Jahre'].map(year => (
                                        <button key={year} className="p-8 border-2 border-gray-100 rounded-[2rem] font-black text-xl hover:border-[#1A758D] hover:text-[#1A758D] hover:bg-[#1A758D]/5 transition-all uppercase tracking-tighter">
                                            {year}
                                        </button>
                                    ))}
                                </div>
                            </div>
                        )}
                        {step === 4 && (
                            <div className="space-y-10 animate-fade-in">
                                <h3 className="text-3xl lg:text-4xl font-black mb-10 text-center lg:text-left">4. Steuerpflichtige Angaben</h3>
                                <div>
                                    <label className="block text-xs font-black text-gray-400 uppercase tracking-widest mb-4">Ihr persönlicher Grenzsteuersatz (%)</label>
                                    <div className="flex flex-col gap-6">
                                        <input type="range" min="14" max="45" className="w-full h-3 bg-gray-100 rounded-lg appearance-none cursor-pointer accent-[#1A758D]" />
                                        <div className="flex justify-between text-2xl font-black text-[#1a1a1a]">
                                            <span>14%</span>
                                            <span className="text-4xl text-[#1A758D]">42%</span>
                                            <span>45%</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        )}
                        {step === 5 && (
                            <div className="text-center space-y-10 animate-bounce-in">
                                <div className="w-32 h-32 bg-[#1A758D]/10 text-[#1A758D] rounded-full flex items-center justify-center mx-auto mb-8 shadow-inner">
                                    <svg className="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="4" d="M5 13l4 4L19 7" /></svg>
                                </div>
                                <h3 className="text-4xl lg:text-5xl font-black mb-4">Analyse abgeschlossen!</h3>
                                <p className="text-gray-500 text-xl font-medium mb-12">Ihre potenzielle Steuerersparnis wartet. <br className="hidden md:block"/> Hinterlassen Sie Ihre E-Mail für das detaillierte Ergebnis.</p>
                                
                                <div className="max-w-md mx-auto space-y-6">
                                    <input type="email" className="w-full p-6 bg-gray-50 border-2 border-transparent focus:border-[#1A758D]/20 focus:bg-white rounded-3xl outline-none font-bold text-xl text-center transition-all shadow-sm" placeholder="ihre@email.de" />
                                    <button className="w-full bg-[#1A758D] text-white py-6 rounded-[2rem] text-2xl font-black uppercase tracking-[0.1em] hover:bg-[#145A6C] transition-all transform hover:scale-[1.05] shadow-[0_30px_60px_-15px_rgba(0,172,64,0.4)]">Ergebnis jetzt senden</button>
                                </div>
                            </div>
                        )}

                        {step < 5 && (
                            <div className="flex flex-col sm:flex-row gap-6 mt-16 lg:mt-24">
                                {step > 1 && (
                                    <button onClick={prevStep} className="flex-1 py-6 border-[3px] border-gray-100 rounded-3xl font-black text-gray-400 hover:bg-gray-50 hover:text-gray-600 transition-all uppercase tracking-widest text-sm">Zurück</button>
                                )}
                                <button onClick={nextStep} className="flex-[2] py-6 bg-[#1A758D] text-white rounded-3xl font-black text-xl hover:bg-[#145A6C] transition-all transform hover:scale-[1.03] active:scale-95 shadow-[0_20px_40px_-5px_rgba(0,172,64,0.25)] uppercase tracking-widest">
                                    {step === 4 ? 'Ergebnis berechnen' : 'Weiter zum nächsten Schritt'}
                                </button>
                            </div>
                        )}
                    </div>
                </div>
            </div>
        </section>
    );
};

