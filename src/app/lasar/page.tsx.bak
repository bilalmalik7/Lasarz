const FaqSection = () => {
  const [openIndex, setOpenIndex] = useState(0);
  const faqs = [
    { q: "Was genau ist ein LASARZ Gutachten?", a: "Ein LASARZ Gutachten ist eine fachkundige, rechtssichere Stellungnahme zur tatsächlich kürzeren Restnutzungsdauer eines Gebäudes. Es basiert auf fundierten Bausubstanz-Analysen und gesetzlichen Bewertungsmethoden, um die Abschreibung (AfA) beim Finanzamt zu optimieren." },
    { q: "Wird das Gutachten vom Finanzamt anerkannt?", a: "Ja, zu 100%. Unsere Gutachten werden von zertifizierten Sachverständigen nach DIN EN ISO/IEC 17024 erstellt. Diese Qualifikation wird von der Finanzverwaltung seit 2023 ausdrücklich gefordert und sichert die höchste Akzeptanzquote." },
    { q: "Was kostet die Erstellung?", a: "Unsere transparenten Pauschalpreise richten sich nach der Wohnfläche. Für ein Standard-Einfamilienhaus oder eine ETW liegt das Honorar bei moderaten 946,05€ zzgl. MwSt. In Anbetracht der oft fünfstelligen Steuerersparnis amortisiert sich das Investment meist im ersten Jahr." },
    { q: "Gibt es eine Geld-zurück-Garantie?", a: "Ja! Sollte ein durch uns erstelltes Gutachten trotz unserer Fachbegleitung im Einspruchsverfahren final vom Finanzamt nicht anerkannt werden, erstatten wir das gezahlte Honorar zu 100% zurück." },
  ];

  return (
    <section className="py-32 bg-gray-50 px-6 font-sans">
      <div className="max-w-4xl mx-auto">
        <div className="text-center mb-24">
            <span className="text-gray-300 font-black uppercase tracking-[0.4em] text-[11px] mb-4 block">Knowledge Base</span>
            <h2 className="text-5xl lg:text-7xl font-black tracking-tighter mb-8 leading-tight">Häufig gestellte Fragen</h2>
            <p className="text-gray-500 text-[11px] font-black uppercase tracking-[0.2em] border-2 border-gray-200 inline-block px-4 py-1.5 rounded-full">Support & Beratung</p>
        </div>
        
        <div className="space-y-6">
          {faqs.map((faq, i) => (
            <div key={i} className={`bg-white rounded-[2.5rem] shadow-[0_15px_30px_-5px_rgba(0,0,0,0.03)] border transition-all duration-500 overflow-hidden ${openIndex === i ? 'border-[#1A758D]/30 ring-4 ring-[#1A758D]/5' : 'border-gray-100'}`}>
              <button 
                onClick={() => setOpenIndex(openIndex === i ? -1 : i)}
                className="w-full p-10 text-left flex justify-between items-center hover:bg-gray-50/50 transition-all transition-colors"
              >
                <span className="font-black text-xl lg:text-2xl text-[#1a1a1a] tracking-tight pr-10">{faq.q}</span>
                <div className={`w-12 h-12 rounded-full border-2 flex items-center justify-center transition-all flex-shrink-0 ${openIndex === i ? 'bg-[#1A758D] border-[#1A758D] text-white rotate-45' : 'bg-white border-gray-100 text-gray-400 group-hover:border-[#1A758D]'}`}>
                   <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="3" d="M12 4v16m8-8H4" /></svg>
                </div>
              </button>
              {openIndex === i && (
                <div className="px-10 pb-10 text-gray-500 text-lg leading-relaxed font-medium animate-slide-down">
                  {faq.a}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  );
};

