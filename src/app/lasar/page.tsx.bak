                <img src={ASSETS.googleReviews} alt="Google Reviews" className="h-48 w-auto object-contain" />
             </div>
             
             <div className="grid grid-cols-2 gap-6 w-full max-w-md">
                <div className="bg-white/10 backdrop-blur-lg p-8 rounded-[2rem] border border-white/20 text-center flex flex-col justify-center">
                    <p className="text-4xl font-black mb-1">10k+</p>
                    <p className="text-[10px] uppercase font-black opacity-60 tracking-widest">Gutachten jährlich</p>
                </div>
